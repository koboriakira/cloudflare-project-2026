{
  "name": "cloudflare-project-2026",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bash bin/dev.sh",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:staging": "playwright test --config playwright.staging.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "reset-db": "bash bin/reset-db.sh",
    "lint": "npx @biomejs/biome check src/",
    "lint:fix": "npx @biomejs/biome check --write src/",
    "generate:openapi": "npx tsx scripts/generate-openapi.ts",
    "judges": "bash judges/run-all.sh"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.5.1",
    "@sentry/cloudflare": "^10.62.0",
    "hono": "^4.12.27",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@cloudflare/workers-types": "^5.20260714.1",
    "@playwright/test": "^1.61.1",
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.105.0"
  }
}
